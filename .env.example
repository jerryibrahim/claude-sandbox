# Host code tree mounted read-write at /code; run.sh only accepts repo paths
# under it. Optional; defaults to $HOME/code. Must be an absolute path (used
# verbatim — no ~/$HOME expansion). Tip: to make host paths match the container's
# /code, symlink /code -> $HOME/code on the host and set SANDBOX_ROOT=/code.
#SANDBOX_ROOT=/code

# Host directory bind-mounted as Claude's home (persistent state, history,
# credentials, .claude.json backups). Optional; defaults to /Users/claude.
CLAUDE_HOME_HOST=/Users/claude

# Claude Authentication for the container (pick ONE; precedence is:
#   1. ANTHROPIC_API_KEY            (API billing. Works on any host)
#   2. CLAUDE_CODE_OAUTH_TOKEN      (generated by `claude setup-token` on host)   
#   3. CLAUDE_HOME_HOST/.claude/.credentials.json (generated by `claude /login` in-container)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=


# GitHub OAuth token (for private repos). Generate on host with:
#   gh auth token
GH_TOKEN=


# Idle auto-stop, in seconds. The holder (PID 1) exits when no session has run
# for this long, which stops the container. Optional; defaults to 1800 (30 min).
#SANDBOX_IDLE_TIMEOUT=1800


# Linux (or macOS default ssh-agent): point this at the host agent socket. The
# entrypoint relays it to the fixed SSH_AUTH_SOCK=/run/agent/ssh.sock sessions
# use. Mutually exclusive with the gpg-agent bridge ports above.
#SSH_AUTH_SOCK_HOST=/run/user/1000/gnupg/S.gpg-agent.ssh


# macOS agent bridge (optional). When your SSH/GPG keys live in gpg-agent
# (e.g. a YubiKey), Docker Desktop can't forward them directly. Uncomment these,
# match the ports in macos-agent-bridge.sh, run that script on the host, and
# restart the container. Leave unset on Linux (use SSH_AUTH_SOCK_HOST instead).
#SSH_AGENT_BRIDGE_PORT=9018
#GPG_AGENT_BRIDGE_PORT=9019

