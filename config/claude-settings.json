{
  "permissions": {
    "deny": [
      "Bash(dd *of=/dev/*)",
      "Bash(mkfs*)",
      "Bash(rm -rf *)",
      "Bash(curl *| sh*)",
      "Bash(curl *| bash*)",
      "Bash(wget *| sh*)",
      "Bash(wget *| bash*)",
      "Bash(helm install *)",
      "Bash(helm upgrade *)",
      "Bash(helm uninstall *)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout . *)",
      "Bash(make docker-reset)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/opt/claude-sandbox/deny-check.sh"
          }
        ]
      }
    ]
  }
}
